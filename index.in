    <div class="bell-row reveal">
      <svg class="bell" viewBox="0 0 30 46" xmlns="http://www.w3.org/2000/svg"><g fill="none" stroke="#c8a04d" stroke-width="1.3"><path d="M15,0 L15,6"/><path d="M8,6 L22,6 C24,6 25,8 25,10 L25,26 C25,30 20,34 15,34 C10,34 5,30 5,26 L5,10 C5,8 6,6 8,6 Z"/><circle cx="15" cy="38" r="2.6" fill="#c8a04d" stroke="none"/><path d="M15,34 L15,36"/></g></svg>
      <svg class="bell" viewBox="0 0 30 46" xmlns="http://www.w3.org/2000/svg"><g fill="none" stroke="#c8a04d" stroke-width="1.3"><path d="M15,0 L15,6"/><path d="M8,6 L22,6 C24,6 25,8 25,10 L25,26 C25,30 20,34 15,34 C10,34 5,30 5,26 L5,10 C5,8 6,6 8,6 Z"/><circle cx="15" cy="38" r="2.6" fill="#c8a04d" stroke="none"/><path d="M15,34 L15,36"/></g></svg>
      <svg class="bell" viewBox="0 0 30 46" xmlns="http://www.w3.org/2000/svg"><g fill="none" stroke="#c8a04d" stroke-width="1.3"><path d="M15,0 L15,6"/><path d="M8,6 L22,6 C24,6 25,8 25,10 L25,26 C25,30 20,34 15,34 C10,34 5,30 5,26 L5,10 C5,8 6,6 8,6 Z"/><circle cx="15" cy="38" r="2.6" fill="#c8a04d" stroke="none"/><path d="M15,34 L15,36"/></g></svg>
      <svg class="bell" viewBox="0 0 30 46" xmlns="http://www.w3.org/2000/svg"><g fill="none" stroke="#c8a04d" stroke-width="1.3"><path d="M15,0 L15,6"/><path d="M8,6 L22,6 C24,6 25,8 25,10 L25,26 C25,30 20,34 15,34 C10,34 5,30 5,26 L5,10 C5,8 6,6 8,6 Z"/><circle cx="15" cy="38" r="2.6" fill="#c8a04d" stroke="none"/><path d="M15,34 L15,36"/></g></svg>
      <svg class="bell" viewBox="0 0 30 46" xmlns="http://www.w3.org/2000/svg"><g fill="none" stroke="#c8a04d" stroke-width="1.3"><path d="M15,0 L15,6"/><path d="M8,6 L22,6 C24,6 25,8 25,10 L25,26 C25,30 20,34 15,34 C10,34 5,30 5,26 L5,10 C5,8 6,6 8,6 Z"/><circle cx="15" cy="38" r="2.6" fill="#c8a04d" stroke="none"/><path d="M15,34 L15,36"/></g></svg>
    </div>
    <h2 class="reveal">Two Hearts, One Beginning</h2>
    <p class="blurb reveal">The beginning of forever. Two families come together in joy to bless the union of Dileep and Nithya, as they take their first sacred step towards a lifetime of togetherness.</p>
    <div class="couple-cards">
      <div class="couple-card reveal">
        <div class="initial">D</div>
        <div class="role">Groom</div>
        <div class="name-full">Munagapati Dileep Kumar</div>
      </div>
      <div class="couple-divider reveal">&amp;</div>
      <div class="couple-card reveal">
        <div class="initial">N</div>
        <div class="role">Bride</div>
        <div class="name-full">Bhrugubanda Naga Nithya</div>
      </div>
    </div>
  </section>

  <!-- EVENT -->
  <section id="event" class="section">
    <div class="section-label reveal">Engagement Ceremony</div>
    <h2 class="reveal">Nischitartham</h2>
    <div class="event-card reveal">
      <div class="telugu-tag telugu">నిశ్చితార్థం</div>
      <h3>The Engagement</h3>
      <div class="date-line">Saturday, 15th August 2026</div>
      <div class="time-line">10:33 AM onwards</div>
      <hr>
      <div class="venue-name">Green Treat Banquet Hall</div>
      <div class="venue-loc">Srinagar Colony, Kothapet</div>
      <a class="map-link" href="#map">View Map ↓</a>
    </div>
  </section>

  <!-- COUNTDOWN -->
  <section id="countdown" class="section">
    <div class="section-label reveal">The Countdown</div>
    <h2 class="reveal">We Can't Wait to Celebrate With You</h2>
    <div class="timer reveal">
      <div class="unit"><div class="num" id="cd-days">00</div><div class="lbl">Days</div></div>
      <div class="unit"><div class="num" id="cd-hours">00</div><div class="lbl">Hours</div></div>
      <div class="unit"><div class="num" id="cd-mins">00</div><div class="lbl">Mins</div></div>
      <div class="unit"><div class="num" id="cd-secs">00</div><div class="lbl">Secs</div></div>
    </div>
  </section>

  <!-- MAP -->
  <section id="map" class="section">
    <div class="section-label reveal">Getting There</div>
    <h2 class="reveal">Find Your Way</h2>
    <p class="reveal">Join us for the Engagement ceremony at <strong>Green Treat Banquet Hall</strong>, Srinagar Colony, Kothapet.</p>
    <iframe class="reveal" loading="lazy" referrerpolicy="no-referrer-when-downgrade"
      src="https://maps.google.com/maps?q=Green+Treat+Banquet+Hall,+Srinagar+Colony,+Kothapet,+Hyderabad&t=&z=15&ie=UTF8&iwloc=&output=embed">
    </iframe>
    <br>
    <a class="open-map-btn reveal" href="https://share.google/885E78PeLz7XEBQMU" target="_blank" rel="noopener">Open in Google Maps</a>
  </section>

  <!-- CLOSING -->
  <section id="closing" class="section">
    <svg class="peacock-feather reveal" viewBox="0 0 60 90" xmlns="http://www.w3.org/2000/svg">
      <g fill="none" stroke="#c8a04d" stroke-width="1.2">
        <path d="M30,90 L30,30"/>
        <ellipse cx="30" cy="18" rx="16" ry="20"/>
        <ellipse cx="30" cy="18" rx="9" ry="12" fill="#155c4d" stroke="#c8a04d"/>
        <circle cx="30" cy="18" r="4" fill="#c8a04d" stroke="none"/>
      </g>
    </svg>
    <svg class="kolam" viewBox="0 0 200 40" xmlns="http://www.w3.org/2000/svg">
      <circle cx="10" cy="20" r="3"/><circle cx="30" cy="20" r="3"/><circle cx="50" cy="20" r="3"/>
      <circle cx="70" cy="20" r="3"/><circle cx="100" cy="20" r="3"/><circle cx="130" cy="20" r="3"/>
      <circle cx="150" cy="20" r="3"/><circle cx="170" cy="20" r="3"/><circle cx="190" cy="20" r="3"/>
      <path d="M10,20 C25,0 35,0 50,20 C65,40 75,40 90,20"/>
      <path d="M110,20 C125,0 135,0 150,20 C165,40 175,40 190,20"/>
    </svg>
    <div class="full-names reveal">Munagapati Dileep Kumar <span class="amp">&amp;</span> Bhrugubanda Naga Nithya</div>
    <div class="families-tag reveal">Together with their families</div>
    <div class="hashtag reveal">#D&amp;N</div>
    <div class="date-stamp reveal">15 · 08 · 2026</div>
  </section>

</div>

<!-- ============ MUSIC ============ -->
<button id="music-toggle" aria-label="Toggle music" aria-pressed="false">
  <svg viewBox="0 0 24 24" fill="none">
    <rect class="bar" x="4" y="10" width="3" height="6" rx="1" fill="currentColor"/>
    <rect class="bar" x="10.5" y="6" width="3" height="14" rx="1" fill="currentColor"/>
    <rect class="bar" x="17" y="10" width="3" height="10" rx="1" fill="currentColor"/>
  </svg>
</button>
<!--
  Add your own Telugu traditional / Carnatic instrumental track:
  1. Place an mp3 file named "music.mp3" in the same folder as this file, OR
  2. Change the src below to a URL of a track you have rights to use.
-->
<audio id="bgm" loop preload="none">
  <source src="music.mp3" type="audio/mpeg">
</audio>

<script>
  // ---- open invitation ----
  const cover = document.getElementById('cover');
  const site = document.getElementById('site');
  const openBtn = document.getElementById('openBtn');
  const bgm = document.getElementById('bgm');
  const musicToggle = document.getElementById('music-toggle');

  function openInvitation(){
    cover.classList.add('hidden');
    site.classList.add('revealed');
    document.body.style.overflow = 'auto';
    bgm.play().then(()=>{
      musicToggle.classList.add('playing');
      musicToggle.setAttribute('aria-pressed','true');
    }).catch(()=>{ /* autoplay blocked, user can tap the music button */ });
    window.scrollTo(0,0);
  }
  openBtn.addEventListener('click', openInvitation);

  musicToggle.addEventListener('click', ()=>{
    if(bgm.paused){
      bgm.play().catch(()=>{});
      musicToggle.classList.add('playing');
      musicToggle.setAttribute('aria-pressed','true');
    } else {
      bgm.pause();
      musicToggle.classList.remove('playing');
      musicToggle.setAttribute('aria-pressed','false');
    }
  });

  // ---- countdown ----
  const target = new Date('2026-08-15T10:33:00+05:30').getTime();
  function updateCountdown(){
    const now = Date.now();
    const diff = Math.max(0, target - now);
    const d = Math.floor(diff / 86400000);
    const h = Math.floor((diff % 86400000) / 3600000);
    const m = Math.floor((diff % 3600000) / 60000);
    const s = Math.floor((diff % 60000) / 1000);
    document.getElementById('cd-days').textContent = String(d).padStart(2,'0');
    document.getElementById('cd-hours').textContent = String(h).padStart(2,'0');
    document.getElementById('cd-mins').textContent = String(m).padStart(2,'0');
    document.getElementById('cd-secs').textContent = String(s).padStart(2,'0');
  }
  updateCountdown();
  setInterval(updateCountdown, 1000);

  // ---- reveal on scroll ----
  const revealEls = document.querySelectorAll('.reveal');
  const io = new IntersectionObserver((entries)=>{
    entries.forEach(entry=>{
      if(entry.isIntersecting){
        entry.target.classList.add('in');
        io.unobserve(entry.target);
      }
    });
  }, {threshold:0.2});
  revealEls.forEach(el=>io.observe(el));

  // ---- falling flower petals ----
  (function(){
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const field = document.getElementById('petal-field');
    const colors = ['#c8a04d', '#e9a23a', '#8a1c3d', '#f3e3bb'];
    const petalCount = window.innerWidth < 600 ? 9 : 16;

    function makePetal(){
      const p = document.createElement('div');
      p.className = 'petal';
      const size = 10 + Math.random()*10;
      const startX = Math.random()*100;
      const drift = (Math.random()*160 - 80) + 'px';
      const duration = 9 + Math.random()*8;
      const delay = Math.random()*duration;
      const color = colors[Math.floor(Math.random()*colors.length)];
      p.style.left = startX + 'vw';
      p.style.setProperty('--drift', drift);
      p.style.animationDuration = duration + 's';
      p.style.animationDelay = '-' + delay + 's';
      p.innerHTML = '<svg width="'+size+'" height="'+size+'" viewBox="0 0 20 20"><path d="M10,0 C14,4 20,6 10,10 C0,6 6,4 10,0 Z" fill="'+color+'" opacity="0.8"/></svg>';
      field.appendChild(p);
    }
    for(let i=0;i<petalCount;i++) makePetal();
  })();
</script>

</body>
</html>

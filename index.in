<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dileep &amp; Nithya — Engagement Invitation</title>
<meta name="description" content="You are invited to celebrate the engagement of Dileep &amp; Nithya on 15th August 2026">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Marcellus&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Noto+Serif+Telugu:wght@400;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --maroon-deep:#40081a;
    --maroon:#6c1330;
    --maroon-light:#8a1c3d;
    --gold:#c8a04d;
    --gold-light:#e9cd8a;
    --gold-pale:#f3e3bb;
    --ivory:#faf3e2;
    --peacock:#0d3d34;
    --peacock-light:#155c4d;
    --text:#3a1912;
    --text-soft:#6b3626;
  }

  *{box-sizing:border-box; margin:0; padding:0;}

  html{scroll-behavior:smooth;}

  body{
    background:var(--ivory);
    color:var(--text);
    font-family:'Cormorant Garamond', serif;
    overflow-x:hidden;
    -webkit-font-smoothing:antialiased;
  }

  .telugu{font-family:'Noto Serif Telugu', serif;}

  h1,h2,h3, .display{
    font-family:'Marcellus', serif;
    font-weight:400;
    letter-spacing:0.02em;
  }

  @media (prefers-reduced-motion: reduce){
    *{animation-duration:0.01ms !important; animation-iteration-count:1 !important; transition-duration:0.01ms !important; scroll-behavior:auto !important;}
  }

  /* ---------- background texture ---------- */
  .section{
    position:relative;
    width:100%;
    min-height:100vh;
    display:flex;
    flex-direction:column;
    align-items:center;
    justify-content:center;
    text-align:center;
    padding:80px 24px;
    overflow:hidden;
  }

  .bg-motif{
    position:absolute;
    inset:0;
    pointer-events:none;
    opacity:0.06;
    background-image:
      radial-gradient(circle at 10% 15%, var(--maroon) 0, transparent 2px),
      radial-gradient(circle at 30% 40%, var(--maroon) 0, transparent 2px),
      radial-gradient(circle at 55% 10%, var(--maroon) 0, transparent 2px),
      radial-gradient(circle at 80% 30%, var(--maroon) 0, transparent 2px),
      radial-gradient(circle at 20% 70%, var(--maroon) 0, transparent 2px),
      radial-gradient(circle at 65% 60%, var(--maroon) 0, transparent 2px),
      radial-gradient(circle at 90% 80%, var(--maroon) 0, transparent 2px),
      radial-gradient(circle at 40% 90%, var(--maroon) 0, transparent 2px);
    background-size:220px 220px;
  }

  /* ---------- kolam divider ---------- */
  .kolam{
    width:220px;
    max-width:60vw;
    height:auto;
    margin:28px auto;
    opacity:0.85;
  }
  .kolam path, .kolam circle{
    stroke:var(--gold);
    fill:none;
    stroke-width:1.4;
  }

  /* ---------- corner peacock feather ornaments ---------- */
  .corner-motif{
    position:absolute;
    width:120px;
    height:120px;
    opacity:0.5;
    pointer-events:none;
  }
  .corner-motif.tl{top:18px; left:18px;}
  .corner-motif.tr{top:18px; right:18px; transform:scaleX(-1);}
  .corner-motif.bl{bottom:18px; left:18px; transform:scaleY(-1);}
  .corner-motif.br{bottom:18px; right:18px; transform:scale(-1,-1);}

  /* ================= COVER ================= */
  #cover{
    background:radial-gradient(ellipse at 50% 20%, var(--maroon-light) 0%, var(--maroon) 45%, var(--maroon-deep) 100%);
    color:var(--gold-pale);
    cursor:pointer;
  }
  #cover .arch-frame{
    width:min(78vw, 340px);
    margin-bottom:6px;
  }
  #cover .arch-frame path{stroke:var(--gold); fill:none; stroke-width:1.6;}
  #cover .eyebrow{
    letter-spacing:0.35em;
    text-transform:uppercase;
    font-size:0.72rem;
    color:var(--gold-light);
    margin-top:18px;
  }
  #cover .telugu-word{
    font-size:1.6rem;
    color:var(--gold);
    margin-top:10px;
  }
  #cover .cover-names{
    font-size:clamp(2.4rem, 9vw, 4rem);
    margin-top:18px;
    color:var(--gold-pale);
  }
  #cover .cover-amp{
    color:var(--gold);
    font-style:italic;
    padding:0 10px;
  }
  #cover .cover-date{
    margin-top:14px;
    font-size:1.05rem;
    letter-spacing:0.12em;
    color:var(--gold-light);
  }
  #cover .open-btn{
    margin-top:44px;
    border:1px solid var(--gold);
    color:var(--gold-pale);
    background:transparent;
    padding:14px 38px;
    font-family:'Marcellus', serif;
    letter-spacing:0.15em;
    font-size:0.85rem;
    text-transform:uppercase;
    border-radius:2px;
    cursor:pointer;
    transition:background 0.4s ease, color 0.4s ease, letter-spacing 0.4s ease;
  }
  #cover .open-btn:hover, #cover .open-btn:focus-visible{
    background:var(--gold);
    color:var(--maroon-deep);
    letter-spacing:0.22em;
  }
  #cover .open-hint{
    margin-top:14px;
    font-size:0.78rem;
    color:var(--gold-light);
    opacity:0.75;
  }

  .site{
    display:none;
  }
  .site.revealed{display:block; animation:siteFade 1.1s ease both;}
  @keyframes siteFade{from{opacity:0;} to{opacity:1;}}

  #cover.closed{display:flex;}
  #cover.hidden{display:none;}

  /* ================= HERO ================= */
  #hero{
    background:linear-gradient(180deg, var(--ivory) 0%, #f6ead0 100%);
  }
  #hero .together{
    font-size:0.85rem;
    letter-spacing:0.28em;
    text-transform:uppercase;
    color:var(--text-soft);
  }
  #hero .telugu-line{
    margin-top:16px;
    font-size:1.3rem;
    color:var(--maroon);
  }
  #hero h1{
    font-size:clamp(2.8rem, 10vw, 5.2rem);
    color:var(--maroon);
    margin-top:18px;
    line-height:1.05;
  }
  #hero h1 .amp{color:var(--gold); font-style:italic;}
  #hero .honor{
    margin-top:22px;
    max-width:520px;
    font-size:1.2rem;
    color:var(--text-soft);
    font-style:italic;
  }
  #hero .scroll-cue{
    margin-top:60px;
    display:flex;
    flex-direction:column;
    align-items:center;
    gap:8px;
    color:var(--maroon);
    font-size:0.72rem;
    letter-spacing:0.3em;
    text-transform:uppercase;
    animation:bob 2.2s ease-in-out infinite;
  }
  @keyframes bob{
    0%,100%{transform:translateY(0);}
    50%{transform:translateY(8px);}
  }

  /* ================= COUPLE ================= */
  #couple{
    background:var(--maroon-deep);
    color:var(--gold-pale);
  }
  #couple .section-label{
    letter-spacing:0.3em;
    text-transform:uppercase;
    font-size:0.75rem;
    color:var(--gold);
  }
  #couple h2{
    font-size:clamp(2rem, 6vw, 2.8rem);
    margin-top:12px;
    margin-bottom:26px;
    color:var(--gold-pale);
  }
  #couple .blurb{
    max-width:600px;
    font-size:1.15rem;
    line-height:1.75;
    color:var(--gold-light);
    margin-bottom:56px;
  }
  .couple-cards{
    display:flex;
    gap:60px;
    flex-wrap:wrap;
    justify-content:center;
    align-items:flex-start;
  }
  .couple-card{
    display:flex;
    flex-direction:column;
    align-items:center;
    gap:14px;
  }
  .couple-card .initial{
    width:96px; height:96px;
    border:1px solid var(--gold);
    border-radius:50%;
    display:flex; align-items:center; justify-content:center;
    font-family:'Marcellus', serif;
    font-size:2.1rem;
    color:var(--gold);
  }
  .couple-card .role{
    font-size:0.7rem;
    letter-spacing:0.25em;
    text-transform:uppercase;
    color:var(--gold);
  }
  .couple-card .name-full{
    font-family:'Marcellus', serif;
    font-size:1.3rem;
    color:var(--gold-pale);
  }
  .couple-divider{
    color:var(--gold);
    font-size:1.6rem;
    font-style:italic;
    align-self:center;
    margin-top:34px;
  }

  /* ================= EVENT ================= */
  #event{
    background:linear-gradient(180deg, #f6ead0 0%, var(--ivory) 100%);
  }
  #event .section-label{
    letter-spacing:0.3em;
    text-transform:uppercase;
    font-size:0.75rem;
    color:var(--maroon);
  }
  #event h2{
    font-size:clamp(2rem, 6vw, 2.8rem);
    color:var(--maroon);
    margin:12px 0 40px;
  }
  .event-card{
    position:relative;
    width:min(92vw, 460px);
    background:var(--ivory);
    border:1px solid var(--gold);
    padding:44px 34px 38px;
    box-shadow:0 18px 40px -22px rgba(64,8,26,0.45);
  }
  .event-card::before, .event-card::after{
    content:"";
    position:absolute;
    width:22px; height:22px;
    border:1px solid var(--gold);
  }
  .event-card::before{top:10px; left:10px; border-right:none; border-bottom:none;}
  .event-card::after{bottom:10px; right:10px; border-left:none; border-top:none;}
  .event-card .telugu-tag{
    color:var(--maroon);
    font-size:1.1rem;
    margin-bottom:6px;
  }
  .event-card h3{
    color:var(--maroon);
    font-size:1.7rem;
    margin-bottom:16px;
  }
  .event-card .date-line{
    font-size:1.15rem;
    color:var(--text);
    margin-bottom:4px;
  }
  .event-card .time-line{
    font-size:1.05rem;
    color:var(--text-soft);
  }
  .event-card hr{
    border:none;
    border-top:1px solid var(--gold-light);
    margin:20px 0;
    width:60%;
  }
  .event-card .venue-name{
    font-family:'Marcellus', serif;
    font-size:1.2rem;
    color:var(--maroon);
  }
  .event-card .venue-loc{
    font-size:1rem;
    color:var(--text-soft);
    margin-top:4px;
  }
  .event-card .map-link{
    display:inline-block;
    margin-top:22px;
    color:var(--maroon);
    text-decoration:none;
    border-bottom:1px solid var(--gold);
    font-size:0.9rem;
    letter-spacing:0.05em;
    padding-bottom:2px;
  }
  .event-card .map-link:hover{color:var(--gold);}

  /* ================= COUNTDOWN ================= */
  #countdown{
    background:var(--peacock);
    color:var(--gold-pale);
  }
  #countdown .section-label{
    letter-spacing:0.3em;
    text-transform:uppercase;
    font-size:0.75rem;
    color:var(--gold);
  }
  #countdown h2{
    font-size:clamp(1.9rem, 6vw, 2.6rem);
    margin:12px 0 36px;
    color:var(--gold-pale);
  }
  .timer{
    display:flex;
    gap:22px;
    flex-wrap:wrap;
    justify-content:center;
  }
  .timer .unit{
    width:96px;
    padding:18px 0;
    border:1px solid var(--gold);
    background:rgba(200,160,77,0.08);
  }
  .timer .num{
    font-family:'Marcellus', serif;
    font-size:2.3rem;
    color:var(--gold-light);
  }
  .timer .lbl{
    margin-top:6px;
    font-size:0.68rem;
    letter-spacing:0.22em;
    text-transform:uppercase;
    color:var(--gold);
  }

  /* ================= MAP ================= */
  #map{
    background:var(--ivory);
  }
  #map .section-label{
    letter-spacing:0.3em;
    text-transform:uppercase;
    font-size:0.75rem;
    color:var(--maroon);
  }
  #map h2{
    font-size:clamp(2rem, 6vw, 2.8rem);
    color:var(--maroon);
    margin:12px 0 20px;
  }
  #map p{
    max-width:520px;
    color:var(--text-soft);
    font-size:1.1rem;
    margin-bottom:30px;
  }
  #map iframe{
    width:min(92vw, 640px);
    height:340px;
    border:1px solid var(--gold);
    filter:sepia(8%) saturate(1.05);
  }
  #map .open-map-btn{
    margin-top:26px;
    display:inline-block;
    border:1px solid var(--maroon);
    color:var(--maroon);
    padding:12px 30px;
    text-decoration:none;
    font-family:'Marcellus', serif;
    letter-spacing:0.1em;
    font-size:0.85rem;
    transition:background 0.3s ease, color 0.3s ease;
  }
  #map .open-map-btn:hover{background:var(--maroon); color:var(--ivory);}

  /* ================= CLOSING ================= */
  #closing{
    background:radial-gradient(ellipse at 50% 30%, var(--maroon-light) 0%, var(--maroon-deep) 100%);
    color:var(--gold-pale);
    padding-bottom:60px;
  }
  #closing .full-names{
    font-family:'Marcellus', serif;
    font-size:clamp(1.5rem, 5vw, 2.1rem);
    line-height:1.6;
    color:var(--gold-pale);
    margin-bottom:6px;
  }
  #closing .full-names .amp{color:var(--gold); font-style:italic; padding:0 8px;}
  #closing .families-tag{
    font-size:0.9rem;
    color:var(--gold-light);
    margin-bottom:30px;
  }
  #closing .hashtag{
    font-family:'Marcellus', serif;
    font-size:1.1rem;
    letter-spacing:0.08em;
    color:var(--gold);
    margin-top:8px;
  }
  #closing .date-stamp{
    margin-top:18px;
    letter-spacing:0.3em;
    font-size:0.85rem;
    color:var(--gold-light);
  }

  /* ---------- music toggle ---------- */
  #music-toggle{
    position:fixed;
    bottom:22px;
    right:22px;
    width:52px; height:52px;
    border-radius:50%;
    background:var(--maroon-deep);
    border:1px solid var(--gold);
    color:var(--gold-light);
    display:flex; align-items:center; justify-content:center;
    cursor:pointer;
    z-index:50;
    box-shadow:0 6px 18px rgba(64,8,26,0.4);
  }
  #music-toggle svg{width:20px; height:20px;}
  #music-toggle.playing svg .bar{animation:eq 0.9s ease-in-out infinite;}
  #music-toggle .bar:nth-child(2){animation-delay:0.15s;}
  #music-toggle .bar:nth-child(3){animation-delay:0.3s;}
  @keyframes eq{
    0%,100%{transform:scaleY(0.4);}
    50%{transform:scaleY(1);}
  }

  /* reveal-on-scroll */
  .reveal{
    opacity:0;
    transform:translateY(24px);
    transition:opacity 0.9s ease, transform 0.9s ease;
  }
  .reveal.in{opacity:1; transform:translateY(0);}

  /* ---------- floating petals ---------- */
  #petal-field{
    position:fixed;
    inset:0;
    pointer-events:none;
    z-index:40;
    overflow:hidden;
  }
  .petal{
    position:absolute;
    top:-40px;
    opacity:0.85;
    animation-name:petal-fall;
    animation-timing-function:linear;
    animation-iteration-count:infinite;
    will-change:transform;
  }
  .petal svg{display:block;}
  @keyframes petal-fall{
    0%{transform:translate(0,0) rotate(0deg);}
    100%{transform:translate(var(--drift,40px), 110vh) rotate(360deg);}
  }

  /* ---------- diya (oil lamp) ---------- */
  .diya{
    width:46px;
    display:inline-block;
  }
  .diya .flame{
    transform-origin:50% 100%;
    animation:flicker 1.6s ease-in-out infinite;
  }
  @keyframes flicker{
    0%,100%{transform:scale(1,1) rotate(-1deg); opacity:1;}
    30%{transform:scale(0.92,1.08) rotate(2deg); opacity:0.92;}
    60%{transform:scale(1.06,0.94) rotate(-2deg); opacity:1;}
  }
  .diya-pair{
    display:flex;
    align-items:flex-end;
    justify-content:center;
    gap:60px;
    margin-top:6px;
  }

  /* ---------- gopuram silhouette ---------- */
  .gopuram-silhouette{
    width:min(90vw, 520px);
    margin:0 auto;
    opacity:0.9;
  }
  .gopuram-silhouette .glow{
    animation:glow-pulse 3.2s ease-in-out infinite;
    transform-origin:50% 100%;
  }
  @keyframes glow-pulse{
    0%,100%{opacity:0.55;}
    50%{opacity:1;}
  }

  /* ---------- rotating rangoli ---------- */
  .rangoli{
    position:absolute;
    top:50%;
    left:50%;
    width:min(120vw, 780px);
    height:min(120vw, 780px);
    transform:translate(-50%,-50%);
    opacity:0.08;
    animation:spin-slow 90s linear infinite;
    pointer-events:none;
  }
  @keyframes spin-slow{
    from{transform:translate(-50%,-50%) rotate(0deg);}
    to{transform:translate(-50%,-50%) rotate(360deg);}
  }

  /* ---------- temple bells ---------- */
  .bell-row{
    display:flex;
    justify-content:center;
    gap:34px;
    margin:10px 0 30px;
  }
  .bell{
    width:30px;
    transform-origin:50% 0%;
    animation:bell-swing 2.6s ease-in-out infinite;
  }
  .bell:nth-child(2){animation-delay:0.3s;}
  .bell:nth-child(3){animation-delay:0.6s;}
  .bell:nth-child(4){animation-delay:0.15s;}
  .bell:nth-child(5){animation-delay:0.45s;}
  @keyframes bell-swing{
    0%,100%{transform:rotate(-6deg);}
    50%{transform:rotate(6deg);}
  }

  /* ---------- peacock feather accent ---------- */
  .peacock-feather{
    width:64px;
    animation:feather-sway 4s ease-in-out infinite;
    transform-origin:50% 100%;
  }
  @keyframes feather-sway{
    0%,100%{transform:rotate(-4deg);}
    50%{transform:rotate(4deg);}
  }

  @media (max-width:520px){
    .couple-cards{gap:36px;}
    .timer .unit{width:78px; padding:14px 0;}
    .timer .num{font-size:1.8rem;}
    .corner-motif{width:70px; height:70px;}
    .diya-pair{gap:30px;}
    .bell-row{gap:20px;}
  }

  @media (prefers-reduced-motion: reduce){
    .petal{display:none;}
  }
</style>
</head>
<body>

<div id="petal-field"></div>

<!-- ============ COVER ============ -->
<div id="cover" class="section closed">
  <div class="bg-motif"></div>
  <svg class="corner-motif tl" viewBox="0 0 100 100"><path d="M5,95 C5,60 20,50 15,20 C25,45 35,45 30,15 C40,35 50,35 45,10" fill="none" stroke="#c8a04d" stroke-width="1.2"/></svg>
  <svg class="corner-motif tr" viewBox="0 0 100 100"><path d="M5,95 C5,60 20,50 15,20 C25,45 35,45 30,15 C40,35 50,35 45,10" fill="none" stroke="#c8a04d" stroke-width="1.2"/></svg>

  <svg class="gopuram-silhouette" viewBox="0 0 300 220" xmlns="http://www.w3.org/2000/svg">
    <g fill="none" stroke="#c8a04d" stroke-width="1.3">
      <!-- kalasha finial -->
      <circle class="glow" cx="150" cy="14" r="5" fill="#e9cd8a" stroke="none"/>
      <path d="M150,19 L150,30"/>
      <!-- tiers -->
      <path d="M120,30 L180,30 L190,46 L110,46 Z"/>
      <path d="M105,46 L195,46 L208,66 L92,66 Z"/>
      <path d="M88,66 L212,66 L228,90 L72,90 Z"/>
      <path d="M65,90 L235,90 L252,120 L48,120 Z"/>
      <!-- small niches -->
      <circle cx="150" cy="56" r="3"/>
      <circle cx="130" cy="56" r="3"/>
      <circle cx="170" cy="56" r="3"/>
      <circle cx="150" cy="77" r="3"/>
      <circle cx="120" cy="77" r="3"/>
      <circle cx="180" cy="77" r="3"/>
      <circle cx="150" cy="104" r="3"/>
      <circle cx="105" cy="104" r="3"/>
      <circle cx="195" cy="104" r="3"/>
      <!-- main archway -->
      <path d="M48,120 L252,120 L252,215 L48,215 Z"/>
      <path d="M75,215 L75,150 C75,120 100,105 150,105 C200,105 225,120 225,150 L225,215"/>
      <path d="M95,215 L95,155 C95,132 115,120 150,120 C185,120 205,132 205,155 L205,215"/>
    </g>
  </svg>

  <div class="eyebrow">Open Invitation</div>
  <div class="telugu-word telugu">శుభలేఖ</div>
  <div class="cover-names display">Dileep <span class="cover-amp">&amp;</span> Nithya</div>
  <div class="cover-date">15 · 08 · 2026</div>

  <div class="diya-pair">
    <svg class="diya" viewBox="0 0 40 46" xmlns="http://www.w3.org/2000/svg">
      <path class="flame" d="M20,4 C25,12 27,17 20,24 C13,17 15,12 20,4 Z" fill="#e9cd8a"/>
      <ellipse cx="20" cy="30" rx="17" ry="6" fill="none" stroke="#c8a04d" stroke-width="1.4"/>
      <path d="M3,30 C3,38 12,44 20,44 C28,44 37,38 37,30" fill="none" stroke="#c8a04d" stroke-width="1.4"/>
    </svg>
    <svg class="diya" viewBox="0 0 40 46" xmlns="http://www.w3.org/2000/svg">
      <path class="flame" d="M20,4 C25,12 27,17 20,24 C13,17 15,12 20,4 Z" fill="#e9cd8a"/>
      <ellipse cx="20" cy="30" rx="17" ry="6" fill="none" stroke="#c8a04d" stroke-width="1.4"/>
      <path d="M3,30 C3,38 12,44 20,44 C28,44 37,38 37,30" fill="none" stroke="#c8a04d" stroke-width="1.4"/>
    </svg>
  </div>

  <button class="open-btn" id="openBtn">Open Invitation</button>
  <div class="open-hint">Tap to begin the celebration</div>
</div>

<!-- ============ SITE ============ -->
